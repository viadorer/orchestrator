# ===========================================
# Orchestrator - Environment Variables
# ===========================================
# Zkopíruj tento soubor jako .env.local a doplň hodnoty:
#   cp .env.example .env.local
#
# UPOZORNĚNÍ: .env.local je v .gitignore — NIKDY ho neukládej do Gitu.
# Při kompromitaci klíče okamžitě rotuj v dashboardu daného providera.

# ------------------------------------------
# Supabase
# ------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------------------------------------------
# Gemini AI
# ------------------------------------------
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key-here

# ------------------------------------------
# getLate.dev (Social Media Publishing)
# ------------------------------------------
GETLATE_API_KEY=your-getlate-api-key
GETLATE_API_URL=https://api.getlate.dev/v1

# ------------------------------------------
# Vercel Cron Security
# ------------------------------------------
# Min 16 znaků, doporučeno openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# ------------------------------------------
# Cloudflare R2 Storage (volitelné — fallback je Supabase Storage)
# ------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ------------------------------------------
# GitHub publikování (volitelné — pro blog + AIO injekci)
# ------------------------------------------
# Token musí mít scope `contents:write` jen na konkrétní repos.
GITHUB_PAT=
GITHUB_OWNER=
